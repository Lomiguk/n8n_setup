# ---------------------------------------------------------------------------
# Domains
# ---------------------------------------------------------------------------
# Point each hostname to the VPS public IP with DNS A/AAAA records before deploy.
DOMAIN_N8N=n8n.example.com
DOMAIN_MINIO_CONSOLE=minio.example.com
DOMAIN_MINIO_API=s3.example.com
DOMAIN_DOZZLE=logs.example.com

# ---------------------------------------------------------------------------
# Traefik / Let's Encrypt
# ---------------------------------------------------------------------------
SSL_EMAIL=admin@example.com

# External Docker network names created by deploy.sh.
TRAEFIK_PUBLIC_NETWORK=web
APP_INTERNAL_NETWORK=n8n_internal

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
# Admin role owns the PostgreSQL server and can create additional databases.
# Keep this credential out of n8n unless a workflow explicitly needs DB admin.
POSTGRES_ADMIN_USER=postgres_admin
POSTGRES_ADMIN_PASSWORD=change-me-admin-password
POSTGRES_DEFAULT_DB=postgres

# n8n application database and least-privilege application user.
N8N_DB_NAME=n8n
N8N_DB_USER=n8n
N8N_DB_PASSWORD=change-me-n8n-db-password

# ---------------------------------------------------------------------------
# n8n
# ---------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=change-me-64-hex-characters

# Set to the same timezone used by the VPS or your users.
GENERIC_TIMEZONE=UTC

# Optional: set a public timezone label inside n8n.
TZ=UTC

# ---------------------------------------------------------------------------
# MinIO
# ---------------------------------------------------------------------------
# Root user should be a non-obvious admin username, not "admin".
MINIO_ROOT_USER=minio_root
MINIO_ROOT_PASSWORD=change-me-minio-root-password

# ---------------------------------------------------------------------------
# Dozzle
# ---------------------------------------------------------------------------
# Dozzle uses native simple authentication. deploy.sh reads these values and
# generates the encrypted users.yml file before starting the stack.
DOZZLE_USERNAME=admin
DOZZLE_PASSWORD=change-me-to-a-strong-password

# ---------------------------------------------------------------------------
# Local Backups
# ---------------------------------------------------------------------------
# Runs daily at 03:00 server time by default.
BACKUP_CRON_EXPRESSION=0 3 * * *

# Strict local retention policy for low-disk VPS hosts.
# 0 means prune old backups immediately; docker-compose.yml also uses a fixed
# backup filename so each run overwrites the previous archive.
BACKUP_RETENTION_DAYS=0
